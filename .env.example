# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key...

# Backend API
VITE_API_BASE=http://localhost:3001
# Production/demo must point to the Xaidus backend Render web service, not the social scraper.
# Example: VITE_API_BASE=https://xaidusappdemo.onrender.com

# Demo mode (only set to true in development)
# VITE_DEMO_MODE=true
