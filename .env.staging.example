# Frontend — Staging Environment
# Copy to .env.staging and fill in values

# Supabase (same project, or staging-specific)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key...

# Backend API (Render staging service URL)
VITE_API_BASE=https://dus-api-staging.onrender.com
# Never use the social profile scraper URL here. Put that in Render backend env as SOCIAL_PROFILE_SCRAPER_URL.
