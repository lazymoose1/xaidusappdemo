# Server Environment Variables
# Copy this file to .env and fill in your values

# Database (MongoDB Atlas via Mongoose)
MONGODB_URI=mongodb+srv://dus_app_user:<password>@<cluster>.mongodb.net/dus?retryWrites=true&w=majority

# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# App
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
SYSTEM_API_KEY=generate-a-random-32-char-string
TOKEN_ENCRYPTION_KEY=generate-a-random-64-hex-string

# OpenAI (optional - mock fallback used if not set)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-turbo-preview

# Social OAuth (data access, not login)
# GOOGLE_CLIENT_ID=
# TWITTER_CLIENT_ID=

# Email (SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@dus.app
