# Server — Staging Environment
# Copy to server/.env.staging and fill in values
# These are also set as environment variables in the Render staging service

# Database (MongoDB Atlas — staging cluster)
MONGODB_URI=mongodb+srv://dus_app_user:<password>@dus-staging-cluster.<id>.mongodb.net/dus?retryWrites=true&w=majority&appName=dus-staging-cluster

# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# App
NODE_ENV=staging
PORT=3001
FRONTEND_ORIGIN=https://dus-staging.onrender.com
SYSTEM_API_KEY=generate-a-random-32-char-string
TOKEN_ENCRYPTION_KEY=generate-a-random-64-hex-string

# OpenAI
OPENAI_API_KEY=sk-...
