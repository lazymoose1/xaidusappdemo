# Server — Production Environment
# Copy to server/.env.production and fill in values
# These are also set as environment variables in the Render production service

# Database (MongoDB Atlas — production cluster)
MONGODB_URI=mongodb+srv://dus_app_user:<password>@dus-prod-cluster.<id>.mongodb.net/dus?retryWrites=true&w=majority&appName=dus-prod-cluster

# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# App
NODE_ENV=production
PORT=3001
FRONTEND_ORIGIN=https://dus.app
# Optional comma-separated allowlist for additional frontends, such as demo/staging.
# FRONTEND_ORIGINS=https://dusapp.netlify.app,https://xaidusappdemo.netlify.app
# Optional temporary auth lookup logs for debugging login/role issues.
AUTH_DIAGNOSTICS=false
SYSTEM_API_KEY=generate-a-random-32-char-string
TOKEN_ENCRYPTION_KEY=generate-a-random-64-hex-string

# OpenAI
OPENAI_API_KEY=sk-...
