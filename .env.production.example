# Frontend — Production Environment
# Copy to .env.production and fill in values

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key...

# Backend API — Xaidus app demo Render service URL.
# Also set this in Netlify dashboard → Environment variables so it is not overridden at build time.
VITE_API_BASE=https://xaidusappdemo.onrender.com
# Never use the social profile scraper URL here. Put that in Render backend env as SOCIAL_PROFILE_SCRAPER_URL.
