# Frontend — Production Environment
# Copy to .env.production and fill in values

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key...

# Backend API — Render production service URL.
# MUST match the actual Render API service name (currently social-profile-scraper).
# Also set this in Render dashboard → Build env so it is not overridden at build time.
VITE_API_BASE=https://social-profile-scraper.onrender.com
